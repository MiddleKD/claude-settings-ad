{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node __PLUGIN_DIR__/plugin/hooks/session-start-bootstrap.js",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node __PLUGIN_DIR__/plugin/hooks/codex-stop.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
